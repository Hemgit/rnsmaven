services:
  web:
    build: ./nginx
    container_name: nginx
    ports:
      - 80:80
    environment: 
     - TOMCAT_IP=tomcat
    network:
     - frontend
    depends_on:
     - tomcat
     - db
  app:
    build: ./tomcat
    container_name: tomcat
    depends_on: 
     - db
    ports:
     - 8080:8080
    environment:
     - DBSERVER=db
    network:
     - frontend
     - backend
  db:
    build: ./mariadb
    container_name: mariadb
    network:
     - backend
    volume:
     - db_data:/var/lib/mysql

 
volumes:
   name: db_data
   
   
   
networks:
   - frontend
   - backend